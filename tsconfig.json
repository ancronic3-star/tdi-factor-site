function runDevChecks(rows: ScannerRow[]) {
  console.assert(rows.length > 0, 'Expected at least one scanner row');
  console.assert(rows.every((row) => row.tdiHistory.length === row.priceHistory.length), 'Expected matching sparkline lengths');
  console.assert(rows.every((row) => row.replay.length > 0), 'Expected replay rows for every coin');
}

function parseHash(): { view: ViewMode; coin?: string } {
  const hash = window.location.hash.replace(/^#/, '');

  if (hash.startsWith('/coin/')) {
    const coin = hash.split('/')[2]?.toUpperCase();
    return { view: 'detail', coin };
  }

  if (hash === '/dashboard') {
    return { view: 'dashboard' };
  }

  return { view: 'login' };
}

function setHash(view: ViewMode, coin = 'LINK') {
  const next = view === 'detail' ? `/coin/${coin}` : view === 'dashboard' ? '/dashboard' : '/login';
  window.location.hash = next;
}

function Sparkline({ data, color = '#22d3ee', height = 120 }: { data: number[]; color?: string; height?: number }) {
  const width = 520;
  const min = Math.min(...data);
  const max = Math.max(...data);
  const range = Math.max(1, max - min);

  const points = data
    .map((value, index) => {
      const x = (index / Math.max(1, data.length - 1)) * width;
      const y = height - ((value - min) / range) * (height - 16) - 8;
      return `${x},${y}`;
    })
    .join(' ');

  return (
    <svg viewBox={`0 0 ${width} ${height}`} className="h-32 w-full" aria-hidden="true">
      <polyline
        fill="none"
        stroke={color}
        strokeWidth="3"
        strokeLinecap="round"
        strokeLinejoin="round"
        points={points}
      />
    </svg>
  );
}

