export default function App() {
  const initial = typeof window !== 'undefined' ? parseHash() : { view: 'login' as ViewMode };
  const [view, setView] = useState<ViewMode>(initial.view);
  const [selectedCoin, setSelectedCoin] = useState<string>(initial.coin && SCANNER_ROWS.some((row) => row.coin === initial.coin) ? initial.coin : 'LINK');

  useEffect(() => {
    runDevChecks(SCANNER_ROWS);
    if (!window.location.hash) {
      setHash('login');
    }

    const syncFromHash = () => {
      const next = parseHash();
      setView(next.view);
      if (next.coin && SCANNER_ROWS.some((row) => row.coin === next.coin)) {
        setSelectedCoin(next.coin);
      }
    };

    syncFromHash();
    window.addEventListener('hashchange', syncFromHash);
    return () => window.removeEventListener('hashchange', syncFromHash);
  }, []);

  const selected = useMemo<ScannerRow>(() => {
    return SCANNER_ROWS.find((row) => row.coin === selectedCoin) ?? SCANNER_ROWS[0];
  }, [selectedCoin]);

  const selectedDrivers = [
    { label: 'Liquidity / traction', value: selected.components.liq, tone: 'from-emerald-400 to-cyan-400' },
    { label: 'Trough / qualifier', value: selected.components.tro, tone: 'from-cyan-400 to-blue-500' },
    { label: 'Pressure', value: selected.components.prs, tone: 'from-fuchsia-400 to-cyan-400' },
    { label: 'Spread', value: selected.components.spr, tone: 'from-slate-300 to-slate-500' },
    { label: 'Momentum', value: selected.components.mom, tone: 'from-blue-400 to-indigo-500' },
  ];

  const goLogin = () => setHash('login');
  const goDashboard = (coin?: string) => {
    if (coin) setSelectedCoin(coin);
    setHash('dashboard');
  };
  const goDetail = (coin: string) => {
    setSelectedCoin(coin);
    setHash('detail', coin);
  };

  if (view === 'detail') {
    return (
      <div className="min-h-screen bg-slate-950 text-slate-100">
        <div className="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(56,189,248,0.08),transparent_28%),radial-gradient(circle_at_bottom_right,rgba(59,130,246,0.08),transparent_32%)]" />
        <div className="relative mx-auto max-w-7xl px-6 py-6">
          <header className="mb-6 flex flex-col gap-4 rounded-[2rem] border border-slate-800 bg-slate-900/80 p-5 shadow-[0_24px_60px_rgba(2,12,27,0.45)] backdrop-blur lg:flex-row lg:items-end lg:justify-between">
            <div>
              <button
                onClick={() => goDashboard(selected.coin)}
                className="mb-4 rounded-full border border-slate-700 px-4 py-2 text-sm text-slate-300 transition hover:border-slate-500 hover:bg-slate-900"
              >
                Back to Dashboard
              </button>
              <div className="text-sm uppercase tracking-[0.22em] text-cyan-300">Coin Detail</div>
              <h1 className="mt-2 text-4xl font-bold text-white">{selected.coin} Intelligence View</h1>
              <p className="mt-2 max-w-3xl text-sm leading-6 text-slate-400">
                Detailed context for {selected.pair}: TDI history, TP-relative interval fit, crest-to-trough framing, and replay evidence built from bot-native snapshots.
              </p>
            </div>
            <div className="grid gap-3 sm:grid-cols-4">
              <InfoChip label="Price" value={selected.price} />
              <InfoChip label="TDI" value={selected.tdi} tone="text-cyan-300" />
              <InfoChip label="Body" value={selected.body} />
              <InfoChip label="Readiness" value={selected.readiness} tone={selected.readinessTone} />
            </div>
          </header>

          <div className="grid gap-6 lg:grid-cols-[1.15fr_0.85fr]">
            <section className="space-y-6">
              <Panel eyebrow="Historical Shape" title="TDI + Price History" badge="Snapshot-driven">
                <div className="grid gap-4 lg:grid-cols-2">
                  <div className="rounded-[1.5rem] border border-slate-800 bg-slate-950 p-4">
                    <div className="mb-2 text-sm font-medium text-slate-300">TDI history</div>
                    <Sparkline data={selected.tdiHistory} color="#22d3ee" />
                    <div className="mt-2 text-sm text-slate-400">TDI rising into the current decision environment.</div>
                  </div>
                  <div className="rounded-[1.5rem] border border-slate-800 bg-slate-950 p-4">
                    <div className="mb-2 text-sm font-medium text-slate-300">Price structure</div>
                    <Sparkline data={selected.priceHistory} color="#60a5fa" />
                    <div className="mt-2 text-sm text-slate-400">Price path used to frame crest-to-trough context for the target move.</div>
                  </div>
                </div>
              </Panel>

              <Panel eyebrow="Structure Framing" title="Crest → Trough Context" badge="TP-relative logic">
                <div className="grid gap-4 md:grid-cols-3">
                  <MiniStat label="Crest" value={selected.structure.crest} />
                  <MiniStat label="Trough" value={selected.structure.trough} />
                  <MiniStat label="Range" value={selected.structure.range} />
                </div>
                <div className="mt-4 rounded-[1.5rem] border border-slate-800 bg-slate-950 p-4 text-sm leading-7 text-slate-400">
                  {selected.structure.note}
                </div>
              </Panel>
            </section>

            <section className="space-y-6">
              <Panel eyebrow="Context Stack" title="Interval Confidence">
                <div className="mt-4 flex flex-wrap gap-3">
                  {selected.ctxStack.map((token) => (
                    <div key={token} className="rounded-full border border-cyan-400/25 bg-cyan-400/10 px-4 py-2 font-mono text-sm text-cyan-300">
                      {token}
                    </div>
                  ))}
                </div>
                <div className="mt-4 rounded-2xl border border-slate-800 bg-slate-950 p-4 text-sm leading-6 text-slate-400">
                  The stack is intentionally layered. This product shows context depth with memory instead of forcing one frozen interval to pretend it explains everything.
                </div>
              </Panel>

              <Panel eyebrow="TP-Relative Fit" title="Interval Alignment">
                <div className="mt-5 space-y-4">
                  {selected.cycleScores.map(([windowLabel, value]) => {
                    const isActive = selected.ctxStack.some((token) => token.toLowerCase().startsWith(windowLabel.toLowerCase()));
                    return <ScoreBar key={windowLabel} label={windowLabel} value={value} active={isActive} />;
                  })}
                </div>
              </Panel>

              <Panel eyebrow="Driver Mix" title="Traction Hierarchy">
                <div className="mt-5 space-y-3">
                  {selectedDrivers.map((driver) => (
                    <MeterBar key={driver.label} label={driver.label} value={driver.value} tone={driver.tone} />
                  ))}
                </div>
                <div className="mt-4 rounded-2xl border border-slate-800 bg-slate-950 p-4 text-sm leading-6 text-slate-400">
                  <span className="text-slate-200">Current read:</span> {selected.traction} with {selected.qualifier.toLowerCase()}. This is an intelligence view built for decision quality, not an execution command panel.
                </div>
              </Panel>
            </section>
          </div>

          <Panel eyebrow="Replay Layer" title="Decision Replay" badge="Evidence, not hype" className="mt-6">
            <div className="overflow-hidden rounded-[1.5rem] border border-slate-800">
              <table className="w-full text-left text-sm">
                <thead className="bg-slate-950 text-slate-400">
                  <tr>
                    <th className="px-4 py-3 font-medium">Timestamp</th>
                    <th className="px-4 py-3 font-medium">Entry TDI</th>
                    <th className="px-4 py-3 font-medium">Context</th>
                    <th className="px-4 py-3 font-medium">4H Move</th>
                    <th className="px-4 py-3 font-medium">Replay Note</th>
                  </tr>
                </thead>
                <tbody>
                  {selected.replay.map((item) => (
                    <tr key={item.ts} className="border-t border-slate-800 bg-slate-950/40">
                      <td className="px-4 py-3 text-slate-300">{item.ts}</td>
                      <td className="px-4 py-3 font-semibold text-cyan-300">{item.entryTdi}</td>
                      <td className="px-4 py-3 text-slate-300">{item.ctx}</td>
                      <td className={`px-4 py-3 font-medium ${item.move4h.startsWith('+') ? 'text-emerald-300' : 'text-rose-300'}`}>
                        {item.move4h}
                      </td>
                      <td className="px-4 py-3 text-slate-400">{item.note}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </Panel>
        </div>
      </div>
    );
  }

  if (view === 'dashboard') {
    return (
      <div className="min-h-screen bg-slate-950 text-slate-100">
        <div className="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(56,189,248,0.08),transparent_28%),radial-gradient(circle_at_bottom_right,rgba(59,130,246,0.08),transparent_32%)]" />
        <div className="relative mx-auto max-w-7xl px-6 py-6">
          <header className="mb-6 flex flex-col gap-4 rounded-[2rem] border border-slate-800 bg-slate-900/80 p-5 shadow-[0_24px_60px_rgba(2,12,27,0.45)] backdrop-blur lg:flex-row lg:items-center lg:justify-between">
            <div>
              <div className="text-sm uppercase tracking-[0.22em] text-cyan-300">Trade Decision Intelligence</div>
              <h1 className="mt-2 text-3xl font-bold text-white">TDI Factor Dashboard</h1>
              <p className="mt-2 max-w-3xl text-sm leading-6 text-slate-400">
                Scanner-first intelligence console built from bot-native diagnostics: liquidity-led traction, trough as context qualifier, and dynamic context stacks aligned to TP-relative structure.
              </p>
            </div>
            <div className="flex flex-wrap gap-3">
              <InfoChip label="Session" value="Private Beta" small />
              <InfoChip label="Layer" value="Observational" small />
              <button
                onClick={goLogin}
                className="rounded-2xl border border-slate-700 px-4 py-3 text-sm font-semibold text-slate-300 transition hover:border-slate-500 hover:bg-slate-900"
              >
                Back to Login
              </button>
            </div>
          </header>

          <div className="grid gap-6 lg:grid-cols-[1.18fr_0.82fr]">
            <Panel eyebrow="Main View" title="TDI Market Scanner" badge="Live observational layer">
              <div className="overflow-hidden rounded-[1.5rem] border border-slate-800">
                <table className="w-full text-left text-sm">
                  <thead className="bg-slate-950 text-slate-400">
                    <tr>
                      <th className="px-4 py-3 font-medium">Coin</th>
                      <th className="px-4 py-3 font-medium">TDI</th>
                      <th className="px-4 py-3 font-medium">Ctx Stack</th>
                      <th className="px-4 py-3 font-medium">Readiness</th>
                      <th className="px-4 py-3 font-medium">Body</th>
                      <th className="px-4 py-3 font-medium">Traction</th>
                    </tr>
                  </thead>
                  <tbody>
                    {SCANNER_ROWS.map((row) => (
                      <tr
                        key={row.coin}
                        onClick={() => setSelectedCoin(row.coin)}
                        className={`cursor-pointer border-t border-slate-800 transition ${selected.coin === row.coin ? 'bg-cyan-400/6' : 'bg-slate-950/40 hover:bg-slate-900'}`}
                      >
                        <td className="px-4 py-3">
                          <div className="font-semibold text-white">{row.coin}</div>
                          <div className="text-xs text-slate-500">{row.pair} • {row.price}</div>
                        </td>
                        <td className="px-4 py-3">
                          <div className="font-semibold text-cyan-300">{row.tdi}</div>
                          <div className="text-xs text-emerald-300">{row.change}</div>
                        </td>
                        <td className="px-4 py-3 font-mono text-xs text-slate-300">{row.ctxStack.join(' | ')}</td>
                        <td className={`px-4 py-3 text-xs font-medium ${row.readinessTone}`}>{row.readiness}</td>
                        <td className="px-4 py-3 text-slate-300">{row.body}</td>
                        <td className="px-4 py-3 text-slate-400">{row.traction}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </Panel>

            <section className="space-y-6">
              <Panel eyebrow="Selected Coin" title={selected.coin}>
                <div className="mt-2 flex items-end justify-between gap-4">
                  <div>
                    <div className="text-slate-400">{selected.pair}</div>
                    <div className="mt-1 text-3xl font-bold text-white">{selected.price}</div>
                  </div>
                  <div className={`rounded-full border px-3 py-1 text-xs font-medium ${selected.readiness === 'Ready' ? 'border-emerald-400/25 bg-emerald-400/10 text-emerald-300' : 'border-amber-400/25 bg-amber-400/10 text-amber-300'}`}>
                    {selected.readiness}
                  </div>
                </div>
                <div className="mt-5 space-y-3 text-sm text-slate-300">
                  <div>TDI Factor: <span className="font-semibold text-cyan-300">{selected.tdi}</span></div>
                  <div>Traction: <span className="font-semibold text-white">{selected.traction}</span></div>
                  <div>Qualifier: <span className="font-semibold text-white">{selected.qualifier}</span></div>
                  <div>Body: <span className="font-semibold text-white">{selected.body}</span></div>
                  <div className="font-mono text-xs text-slate-300">{selected.ctxStack.join(' | ')}</div>
                </div>
                <button
                  onClick={() => goDetail(selected.coin)}
                  className="mt-4 w-full rounded-2xl bg-cyan-400 px-5 py-3 font-semibold text-slate-950 transition hover:scale-[1.01]"
                >
                  Open Coin Detail
                </button>
              </Panel>
            </section>
          </div>

          <div className="mt-6 grid gap-6 xl:grid-cols-[0.95fr_1.05fr_1fr]">
            <Panel eyebrow="Market Bodies" title="Depth Classification">
              <div className="mt-5 grid gap-3">
                {BODY_CARDS.map((card) => (
                  <div key={card.title} className="rounded-2xl border border-slate-800 bg-slate-950 p-4">
                    <div className={`text-lg font-semibold ${card.tone}`}>{card.title}</div>
                    <div className="mt-2 text-sm leading-6 text-slate-400">{card.text}</div>
                  </div>
                ))}
              </div>
            </Panel>

            <Panel eyebrow="Cycle Window" title="TP-Relative Context">
              <div className="mt-5 rounded-[1.5rem] border border-slate-800 bg-slate-950 p-5">
                <div className="mb-4 flex items-center justify-between text-sm">
                  <span className="text-slate-400">Desired TP target</span>
                  <span className="font-semibold text-white">6.2%</span>
                </div>
                <div className="space-y-4">
                  {selected.cycleScores.map(([windowLabel, value]) => {
                    const isActive = selected.ctxStack.some((token) => token.toLowerCase().startsWith(windowLabel.toLowerCase()));
                    return <ScoreBar key={windowLabel} label={windowLabel} value={value} active={isActive} />;
                  })}
                </div>
                <p className="mt-4 text-sm leading-6 text-slate-400">
                  A trough only matters relative to the mountain range that matches the intended move. The product should show interval context, not pretend there is one universal best cycle.
                </p>
              </div>
            </Panel>

            <Panel eyebrow="Live Feed" title="Signal Tape">
              <div className="mt-5 rounded-[1.5rem] border border-slate-800 bg-slate-950 p-4 font-mono text-sm leading-7 text-slate-300">
                {FEED_LINES.map((line, index) => (
                  <div key={index} className="border-b border-slate-900 py-2 last:border-none">
                    {line}
                  </div>
                ))}
              </div>
              <div className="mt-4 rounded-2xl border border-slate-800 bg-slate-950 p-4 text-sm leading-6 text-slate-400">
                Built from bot-native diagnostics: ticker → snapshots → validation → replay → product. No P&amp;L panel here until balance-anchored reporting is trustworthy.
              </div>
            </Panel>
          </div>
        </div>
      </div>
    );
  }

  return (
    <div className="min-h-screen bg-slate-950 text-slate-100">
      <div className="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(56,189,248,0.12),transparent_28%),radial-gradient(circle_at_bottom_right,rgba(59,130,246,0.1),transparent_32%)]" />
      <div className="relative mx-auto max-w-7xl px-6 py-8">
        <header className="mb-8 flex flex-col gap-4 rounded-[2rem] border border-slate-800 bg-slate-900/80 p-5 shadow-[0_24px_60px_rgba(2,12,27,0.45)] backdrop-blur lg:flex-row lg:items-center lg:justify-between">
          <div>
            <div className="text-sm uppercase tracking-[0.22em] text-cyan-300">Trade Decision Intelligence</div>
            <h1 className="mt-2 text-3xl font-bold text-white">TDI Factor Private Beta</h1>
            <p className="mt-2 max-w-3xl text-sm leading-6 text-slate-400">
              Scanner-first market intelligence shaped by bot-native diagnostics: liquidity-led traction, trough as a qualifier,
              dynamic context stacks, replay evidence, and TP-relative structure.
            </p>
          </div>
          <div className="rounded-full border border-emerald-400/25 bg-emerald-400/10 px-4 py-2 text-xs font-medium uppercase tracking-[0.18em] text-emerald-300">
            Secure private access
          </div>
        </header>

        <div className="grid gap-8 lg:grid-cols-[1.05fr_0.95fr] lg:items-start">
          <section className="space-y-6">
            <Panel eyebrow="Entry View" title="Context-aware intelligence, not black-box execution.">
              <p className="mt-4 max-w-3xl text-sm leading-7 text-slate-400">
                This first version is intentionally restrained: a secure front door, a scanner-first dashboard, and a coin detail
                view that explains the decision environment without pretending to be the execution engine.
              </p>

              <div className="mt-6 grid gap-4 sm:grid-cols-3">
                {STATS.map((stat) => (
                  <div key={stat.label} className="rounded-[1.5rem] border border-slate-800 bg-slate-950 p-4">
                    <div className="text-xs uppercase tracking-[0.18em] text-slate-500">{stat.label}</div>
                    <div className="mt-2 text-lg font-semibold text-white">{stat.value}</div>
                  </div>
                ))}
              </div>
            </Panel>

            <div className="grid gap-4 md:grid-cols-3">
              <div className="rounded-[1.75rem] border border-slate-800 bg-slate-900/80 p-5 backdrop-blur">
                <div className="text-sm uppercase tracking-[0.18em] text-cyan-300">Scanner</div>
                <div className="mt-2 text-xl font-semibold text-white">Market view first</div>
                <p className="mt-3 text-sm leading-6 text-slate-400">
                  Rank coins by TDI Factor, show readiness, keep the interval stack visible, and frame traction honestly.
                </p>
              </div>
              <div className="rounded-[1.75rem] border border-slate-800 bg-slate-900/80 p-5 backdrop-blur">
                <div className="text-sm uppercase tracking-[0.18em] text-cyan-300">Context</div>
                <div className="mt-2 text-xl font-semibold text-white">TP-relative structure</div>
                <p className="mt-3 text-sm leading-6 text-slate-400">
                  A trough only matters relative to the mountain range that matches the intended move. The product keeps that visible.
                </p>
              </div>
              <div className="rounded-[1.75rem] border border-slate-800 bg-slate-900/80 p-5 backdrop-blur">
                <div className="text-sm uppercase tracking-[0.18em] text-cyan-300">Replay</div>
                <div className="mt-2 text-xl font-semibold text-white">Evidence over hype</div>
                <p className="mt-3 text-sm leading-6 text-slate-400">
                  Snapshot-driven replay turns past decision environments into readable proof instead of decorative marketing.
                </p>
              </div>
            </div>

            <Panel eyebrow="Signal framing" title="What the product is actually saying">
              <div className="mt-5 grid gap-4 md:grid-cols-2">
                <div className="rounded-[1.5rem] border border-slate-800 bg-slate-950 p-4">
                  <div className="text-sm font-semibold text-white">Liquidity leads</div>
                  <p className="mt-2 text-sm leading-6 text-slate-400">
                    Traction is not presented as one mystical score. The hierarchy stays visible so users can see what is doing the work.
                  </p>
                </div>
                <div className="rounded-[1.5rem] border border-slate-800 bg-slate-950 p-4">
                  <div className="text-sm font-semibold text-white">Trough qualifies</div>
                  <p className="mt-2 text-sm leading-6 text-slate-400">
                    Trough remains important, but it is contextual. The UI avoids overstating it as a universal lead signal.
                  </p>
                </div>
              </div>
            </Panel>
          </section>

          <section className="lg:sticky lg:top-8">
            <AuthCard
              onEnter={() => {
                setSelectedCoin('LINK');
                goDashboard('LINK');
              }}
            />
          </section>
        </div>
      </div>
    </div>
  );
}
